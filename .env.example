VITE_SEARCHAPI_KEY=your_searchapi_key_here
VITE_API_BASE=http://localhost:8000
# Set to true to bypass SearchAPI and stream calls, using local fixture data instead.
# Useful for UI development without consuming API quota.
VITE_MOCK_MODE=false
# Gemini API key — get one at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Active LLM provider: gemini | ollama (can also be toggled in the sidebar at runtime)
VITE_LLM_PROVIDER=gemini
